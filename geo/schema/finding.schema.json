{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "geo/schema/finding.schema.json",
  "type": "object",
  "required": ["id", "category", "endpoint_key", "entity_keys", "status", "severity", "message", "evidence", "reproducibility", "validator_version"],
  "properties": {
    "id": { "type": "string" },
    "category": { "enum": ["identity", "endpoint_availability", "backlink", "metadata", "jsonld", "reproducibility", "chunk_readability"] },
    "endpoint_key": { "type": ["string", "null"] },
    "entity_keys": { "type": "array", "items": { "type": "string" } },
    "status": { "enum": ["pass", "finding", "advisory"] },
    "severity": { "enum": ["info", "warning", "error", "advisory"] },
    "message": { "type": "string" },
    "evidence": { "type": "object" },
    "reproducibility": { "type": "object" },
    "validator_version": { "type": "string" }
  }
}
