    "source_document": "Joint-Workflow.pdf",
    "source_section": "Joint definitions",
    "implementation_status": "metadata-only",
    "operational_status": "not-operational",
    "items": [
      {
        "id": "orchestrator",
        "label": "Orchestrator",
        "role": "Human-controlled message bus and execution-order authority.",
        "responsibilities": [
          "Controls joint invocation order",
          "Passes outputs between isolated joints",
          "Reviews escalations and trace boundaries"
        ],
        "source_document": "Joint-Workflow.pdf",
        "source_section": "Architecture overview; joint definitions",
        "implementation_status": "metadata-only",
        "operational_status": "not-operational"
      },
      {
        "id": "communicator",
        "label": "Communicator",
        "role": "Planner and normalizer that translates raw intent into structured execution plans.",
        "responsibilities": [
          "Parse user input into job-ticket-oriented structure",
          "Prepare routing decisions",
          "Emit planning metadata"
        ],
        "source_document": "Joint-Workflow.pdf",
        "source_section": "Joint definitions",
        "implementation_status": "metadata-only",
        "operational_status": "not-operational"
      },
      {
        "id": "mediator",
        "label": "Mediator",
        "role": "Constraint generator defining enforceable boundaries.",
        "responsibilities": [
          "Produce constraints packet metadata",
          "Define acceptance test expectations",
          "Carry inherited forbidden-pattern references"
        ],
        "source_document": "Joint-Workflow.pdf",
        "source_section": "Joint definitions; forbidden pattern enforcement",
        "implementation_status": "metadata-only",
        "operational_status": "not-operational"
      },
      {
        "id": "drafter",
        "label": "Drafter",
        "role": "Constrained content producer within mediator boundaries.",
        "responsibilities": [
          "Respect constraints packet boundaries",
          "Produce bounded artifact output metadata",
          "Avoid forbidden output patterns"
        ],
        "source_document": "Joint-Workflow.pdf",
        "source_section": "Joint definitions",
        "implementation_status": "metadata-only",
        "operational_status": "not-operational"
      },
      {
        "id": "refiner",
        "label": "Refiner",
        "role": "Quality gate that verifies drafter output and issues verdicts.",
        "responsibilities": [
          "Evaluate constraints and forbidden patterns",
          "Produce minimal patchlist metadata",
          "Issue pass, fail, or escalate verdicts"
        ],
        "source_document": "Joint-Workflow.pdf",
        "source_section": "Joint definitions; T_refiner_patchlist rules",
        "implementation_status": "metadata-only",
        "operational_status": "not-operational"
      },
      {
        "id": "origin",
        "label": "Origin",
        "role": "Commit authority for verified changes and delta briefs.",
        "responsibilities": [
          "Accept only pass-qualified patchlist metadata",
          "Record lineage and delta-brief semantics",
          "Reject non-pass preconditions"
        ],
        "source_document": "Joint-Workflow.pdf",
        "source_section": "Joint definitions; T_origin_commit rules",
        "implementation_status": "metadata-only",
        "operational_status": "not-operational"
      }
    ]
  },
  "pipelines": {
    "source_document": "Joint-Workflow.pdf",
    "source_section": "Pipelines: default_single_capsule",
    "implementation_status": "static-trace-sequence",
    "operational_status": "not-operational",
    "items": [
      {
        "id": "default_single_capsule",
        "label": "Default Single Capsule",
        "description": "Static sequence for showing how intent can move through idempotency, planning, normalization, constraints, drafting, refinement, and origin authority.",
        "retry_policy": "Retry behavior is represented only as static trace policy. v0 implements no runtime retry loops.",
        "steps": [
          {
            "order": "0",
            "joint": "orchestrator",
            "template": "G_IDEMPOTENCY",
            "gate": "G_IDEMPOTENCY",
            "stage_key": "AUTHORITY_CHECK",
            "output": "artifact_content or proceed_signal"
          },
          {
            "order": "1",
            "joint": "communicator",
            "template": "T_comm_execution_plan",
            "gate": "G1",
            "stage_key": "INPUT_FRAME",
            "output": "execution_plan"
          },
          {
            "order": "1A",
            "joint": "orchestrator",
            "template": "ADP-JT-JSON2XML-001",
            "gate": "G1A",
            "stage_key": "PROVENANCE",
            "output": "canonical XML job_ticket"
          },
          {
            "order": "2",
            "joint": "mediator",
            "template": "T_mediator_constraints_packet",
            "gate": "G2",
            "stage_key": "GATE_DECISION",
            "output": "constraints_packet"
          },
          {
            "order": "3",
            "joint": "drafter",
            "template": "T_drafter_constrained_output",
            "gate": "contract_validation",
            "stage_key": "RISK_CLASSIFICATION",
            "output": "drafter_output"
          },
          {
            "order": "4",
            "joint": "refiner",
            "template": "T_refiner_patchlist",
            "gate": "VAL-SAFE-001",
            "stage_key": "RECOVERY_PATH",
            "output": "patchlist"
          },
          {
            "order": "5",
            "joint": "origin",
            "template": "T_origin_commit",
            "gate": "schema_validation",
            "stage_key": "AUDIT_RELEASE",
            "output": "origin_commit"
          }
        ],
        "source_document": "Joint-Workflow.pdf",
        "source_section": "Pipelines: default_single_capsule",
        "implementation_status": "static-trace-sequence",
        "operational_status": "not-operational"
      }
    ]
  },
