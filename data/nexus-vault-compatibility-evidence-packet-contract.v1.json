  "blocking_rules": [
    {
      "id": "only_pinned_commit_can_be_accepted_current_supported",
      "description": "Only the supported pinned Vault commit may use accepted_current_supported."
    },
    {
      "id": "non_pinned_complete_packet_not_supported",
      "description": "A non-pinned candidate may have a complete packet, but it remains candidate_packet_valid_but_not_supported in this pass."
    },
    {
      "id": "incomplete_packet_blocks",
      "description": "Missing or incomplete evidence produces candidate_packet_incomplete."
    },
    {
      "id": "deterministic_identity_failure_blocks",
      "description": "Deterministic identity failure produces candidate_blocked."
    },
    {
      "id": "verdict_or_release_semantics_drift_blocks",
      "description": "Verdict or release eligibility semantics drift produces candidate_incompatible."
    },
    {
      "id": "trace_or_ledger_boundary_violation_blocks",
      "description": "Trace or ledger boundary violation produces candidate_incompatible."
    },
    {
      "id": "generated_artifacts_staged_blocks",
      "description": "Generated .track3-runs artifacts staged produces candidate_blocked."
    },
    {
      "id": "public_claim_escalation_blocks",
      "description": "Public runtime claim escalation produces candidate_blocked."
    }
  ],
  "report_output": {
