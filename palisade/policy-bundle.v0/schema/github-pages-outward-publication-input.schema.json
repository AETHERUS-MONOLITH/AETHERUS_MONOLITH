{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aetherus.local/palisade/policy-bundle.v0/schema/github-pages-outward-publication-input.schema.json",
  "title": "GitHub Pages Outward Publication Palisade Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "policy_surface", "claim_id", "requested_action", "policy_rule_id", "action_identifier",
    "workspace_id", "repository", "repository_id", "repository_ref", "workflow_path", "workflow_sha", "workflow_run_id", "run_attempt",
    "request_id", "authorization_record_id", "execution_identity_sha256", "action_manifest_sha256",
    "artifact_id", "artifact_name", "artifact_run_id", "artifact_run_attempt", "built_artifact_sha256",
    "canonical_public_target", "environment", "permitted_effect", "deploy_executor_sha",
    "phase4_status", "phase4_status_receipt_sha256", "authorization_currently_usable", "authorization_expired", "artifact_expired",
    "operator_assignment_count", "operator_cardinality_exactly_one", "approved_operator_still_valid",
    "request_identity_match", "execution_identity_match", "manifest_digest_match", "artifact_binding_match", "runtime_binding_match",
    "dependency_binding_match", "target_effect_executor_match", "replay_state", "consumption_state"
  ],
  "properties": {
    "schema_version": { "const": "0.5" },
    "policy_surface": { "const": "github_pages_outward_publication_boundary" },
    "claim_id": { "const": "github_pages_outward_publication_authority" },
    "requested_action": { "const": "github_pages_outward_publication@0.1" },
    "policy_rule_id": { "const": "github-pages-outward-publication-authority-v0" },
    "action_identifier": { "const": "github_pages_outward_publication@0.1" },
    "workspace_id": { "const": "9abed891-7950-4937-a2aa-4b957d8a4bd1" },
    "repository": { "const": "AETHERUS-MONOLITH/AETHERUS_MONOLITH" },
    "repository_id": { "const": "1167751543" },
    "repository_ref": { "const": "refs/heads/main" },
    "workflow_path": { "const": ".github/workflows/pages-runtime-config.yml" },
    "workflow_sha": { "$ref": "#/$defs/sha1" },
    "workflow_run_id": { "$ref": "#/$defs/positiveIntegerString" },
    "run_attempt": { "const": 1 },
    "request_id": { "type": "string", "format": "uuid" },
    "authorization_record_id": { "type": "string", "format": "uuid" },
    "execution_identity_sha256": { "$ref": "#/$defs/sha256" },
    "action_manifest_sha256": { "$ref": "#/$defs/sha256" },
    "artifact_id": { "$ref": "#/$defs/positiveIntegerString" },
    "artifact_name": { "const": "github-pages-governable-v0-1" },
    "artifact_run_id": { "$ref": "#/$defs/positiveIntegerString" },
    "artifact_run_attempt": { "const": 1 },
    "built_artifact_sha256": { "$ref": "#/$defs/sha256" },
    "canonical_public_target": { "const": "https://camilocarlone.com/" },
    "environment": { "const": "github-pages" },
    "permitted_effect": { "const": "replace the current GitHub Pages deployment for the canonical target with the exact bound uploaded artifact" },
    "deploy_executor_sha": { "const": "d6db90164ac5ed86f2b6aed7e0febac5b3c0c03e" },
    "phase4_status": { "enum": ["pending", "authorized", "rejected", "consumed", "consumption_failed", "expired"] },
    "phase4_status_receipt_sha256": { "$ref": "#/$defs/sha256" },
    "authorization_currently_usable": { "type": "boolean" },
    "authorization_expired": { "type": "boolean" },
    "artifact_expired": { "type": "boolean" },
    "operator_assignment_count": { "type": "integer", "minimum": 0 },
    "operator_cardinality_exactly_one": { "type": "boolean" },
    "approved_operator_still_valid": { "type": "boolean" },
    "request_identity_match": { "type": "boolean" },
    "execution_identity_match": { "type": "boolean" },
    "manifest_digest_match": { "type": "boolean" },
    "artifact_binding_match": { "type": "boolean" },
    "runtime_binding_match": { "type": "boolean" },
    "dependency_binding_match": { "type": "boolean" },
    "target_effect_executor_match": { "type": "boolean" },
    "replay_state": { "enum": ["unused", "used", "indeterminate"] },
    "consumption_state": { "enum": ["not_consumed", "consumed", "failed", "indeterminate"] }
  },
  "$defs": {
    "sha1": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "positiveIntegerString": { "type": "string", "pattern": "^[1-9][0-9]*$" }
  }
}
